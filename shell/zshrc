# =============================================================================
#  plox-term · ~/.zshrc
#  Arranque mínimo · completado cacheado · color por rol desde la paleta ANSI.
#  Portable: en WSL activa el interop de Windows; en un server Linux lo omite.
# =============================================================================

# --- PATH --------------------------------------------------------------------
typeset -U path PATH
path=("$HOME/.local/bin" "$HOME/bin" $path)

# WSL: sacar /mnt/c del PATH (miles de archivos sobre 9p = arranque lento) y
# puentear las utilidades de Windows por función. En Linux puro no corre.
if [[ -d /mnt/c ]]; then
  _winhome=""
  for _uh in /mnt/c/Users/*(/N); do
    [[ -d "$_uh/AppData/Local/Microsoft/WindowsApps" ]] && _winhome="${_uh%/}" && break
  done
  path=(${path:#/mnt/c/*})
  for _d in \
    "$_winhome/AppData/Local/Programs/Microsoft VS Code/bin" \
    "/mnt/c/Program Files/WezTerm" \
    "$_winhome/AppData/Local/Microsoft/WindowsApps"; do
    [[ -d "$_d" ]] && path+=("$_d")
  done
  unset _uh _d _winhome
  explorer.exe() { /mnt/c/Windows/explorer.exe "$@"; }
  clip.exe()     { /mnt/c/Windows/System32/clip.exe "$@"; }
  open()         { /mnt/c/Windows/explorer.exe "${@:-.}"; }
  pbcopy()       { /mnt/c/Windows/System32/clip.exe; }
fi
export PATH

# --- Historial ---------------------------------------------------------------
HISTFILE="$HOME/.zsh_history"; HISTSIZE=50000; SAVEHIST=50000
setopt EXTENDED_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE \
       HIST_REDUCE_BLANKS HIST_VERIFY INC_APPEND_HISTORY SHARE_HISTORY
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT \
       INTERACTIVE_COMMENTS NO_BEEP ALWAYS_TO_END COMPLETE_IN_WORD

# --- Color por rol via ANSI (sigue el tema activo del terminal) --------------
export EZA_COLORS="uu=90:gu=90:da=90:sn=36:sb=90:ur=32:uw=33:ux=31:ue=31:gr=32:gw=33:gx=31:tr=32:tw=33:tx=31:xx=90:ga=32:gm=33:gd=31:gv=35:gt=36"
export LS_COLORS="di=1;34:ln=36:ex=1;32:or=31:mi=31:*.tar=31:*.gz=31:*.tgz=31:*.zip=31:*.xz=31:*.bz2=31:*.7z=31:*.rar=31:*.zst=31:*.png=35:*.jpg=35:*.jpeg=35:*.gif=35:*.webp=35:*.svg=35:*.mp4=35:*.mov=35:*.md=36:*.json=33:*.lock=90:*.log=90"

# --- Completado cacheado -----------------------------------------------------
autoload -Uz compinit
ZCOMPDUMP="$HOME/.cache/zsh/zcompdump"
[[ -d "$HOME/.cache/zsh" ]] || mkdir -p "$HOME/.cache/zsh"
if [[ -n "$ZCOMPDUMP"(#qN.mh+24) ]]; then compinit -d "$ZCOMPDUMP"; else compinit -C -d "$ZCOMPDUMP"; fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$HOME/.cache/zsh/compcache"
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# --- Herramientas (cada una se activa solo si está instalada) ----------------
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

if command -v fzf >/dev/null; then
  source <(fzf --zsh) 2>/dev/null
  _find=fdfind; command -v fdfind >/dev/null || _find=fd
  export FZF_DEFAULT_COMMAND="$_find --type f --hidden --follow --exclude .git"
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND="$_find --type d --hidden --follow --exclude .git"
  unset _find
  export FZF_DEFAULT_OPTS='--height 45% --layout reverse --border rounded --info inline
    --color=fg:-1,bg:-1,hl:4,fg+:-1,bg+:8,hl+:6,info:5,prompt:5,pointer:6,marker:2,spinner:6,header:4,border:8'
fi

# NVM: carga perezosa (no paga el arranque hasta el primer node/npm/npx/claude)
export NVM_DIR="$HOME/.nvm"
load_nvm() {
  unset -f load_nvm node npm npx nvm claude 2>/dev/null
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"
  command "$@"
}
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  node(){ load_nvm node "$@"; }; npm(){ load_nvm npm "$@"; }; npx(){ load_nvm npx "$@"; }
  nvm(){ load_nvm nvm "$@"; }; claude(){ load_nvm claude "$@"; }
fi

# --- Alias (adaptativos a los nombres de binario de cada distro) --------------
if command -v eza >/dev/null; then
  alias ls='eza --icons=auto --group-directories-first'
  alias ll='eza -lah --icons=auto --group-directories-first --git'
  alias la='eza -a --icons=auto --group-directories-first'
  alias lt='eza --tree --level=2 --icons=auto --group-directories-first'
  alias tree='eza --tree --icons=auto --group-directories-first'
fi
if command -v batcat >/dev/null; then alias cat='batcat --style=plain --paging=never'
elif command -v bat >/dev/null; then alias cat='bat --style=plain --paging=never'; fi
command -v fdfind >/dev/null && ! command -v fd >/dev/null && alias fd='fdfind'
alias gs='git status -sb'; alias ga='git add'; alias gc='git commit'
alias gp='git push'; alias gl='git pull'; alias gd='git diff'
alias ..='cd ..'; alias ...='cd ../..'
export EDITOR="${EDITOR:-nano}"; export VISUAL="$EDITOR"

# --- Plugins (adaptativo; syntax-highlighting SIEMPRE al final) ---------------
for _f in /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
          /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh \
          "$HOME/.local/share/zsh-autosuggestions/zsh-autosuggestions.zsh"; do
  [[ -r "$_f" ]] && { source "$_f"; break; }
done
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
ZSH_AUTOSUGGEST_STRATEGY=(history)
ZSH_AUTOSUGGEST_USE_ASYNC=1
ZSH_AUTOSUGGEST_MANUAL_REBIND=1

command -v starship >/dev/null && eval "$(starship init zsh)"

_fsh="$HOME/.local/share/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
if [[ -r "$_fsh" ]]; then
  source "$_fsh"
  typeset -gA FAST_HIGHLIGHT_STYLES
  FAST_HIGHLIGHT_STYLES[command]='fg=green'
  FAST_HIGHLIGHT_STYLES[builtin]='fg=green'
  FAST_HIGHLIGHT_STYLES[function]='fg=green'
  FAST_HIGHLIGHT_STYLES[precommand]='fg=green,italic'
  FAST_HIGHLIGHT_STYLES[alias]='fg=cyan'
  FAST_HIGHLIGHT_STYLES[unknown-token]='fg=red'
  FAST_HIGHLIGHT_STYLES[reserved-word]='fg=magenta'
  FAST_HIGHLIGHT_STYLES[single-hyphen-option]='fg=magenta'
  FAST_HIGHLIGHT_STYLES[double-hyphen-option]='fg=magenta'
  FAST_HIGHLIGHT_STYLES[path]='fg=default'
  FAST_HIGHLIGHT_STYLES[globbing]='fg=red'
  FAST_HIGHLIGHT_STYLES[single-quoted-argument]='fg=yellow'
  FAST_HIGHLIGHT_STYLES[double-quoted-argument]='fg=yellow'
  FAST_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=yellow'
  FAST_HIGHLIGHT_STYLES[back-quoted-argument]='fg=cyan'
  FAST_HIGHLIGHT_STYLES[variable]='fg=blue'
  FAST_HIGHLIGHT_STYLES[dollar-double-quoted-argument]='fg=blue'
  FAST_HIGHLIGHT_STYLES[redirection]='fg=cyan'
  FAST_HIGHLIGHT_STYLES[commandseparator]='fg=cyan'
  FAST_HIGHLIGHT_STYLES[comment]='fg=8'
  FAST_HIGHLIGHT_STYLES[default]='fg=default'
fi
unset _f _fsh
